# OpenClaw Gateway + fluss-hook plugin (local test, no Fluss)
#
# Plugin installed in extensions/ directory, outputMode=console for verification.
#
# Build context: project root

ARG OPENCLAW_IMAGE=alpine/openclaw:latest
FROM ${OPENCLAW_IMAGE}

USER root

# --- fluss-hook plugin source (extensions/ path) ---
COPY index.ts /home/node/.openclaw/extensions/fluss-hook/index.ts
COPY src/ /home/node/.openclaw/extensions/fluss-hook/src/
COPY openclaw.plugin.json /home/node/.openclaw/extensions/fluss-hook/openclaw.plugin.json
COPY package.json /home/node/.openclaw/extensions/fluss-hook/package.json
COPY tsconfig.json /home/node/.openclaw/extensions/fluss-hook/tsconfig.json

RUN chown -R node:node /home/node/.openclaw/extensions

USER node
