# === LLM Model Configuration ===
# Bailian (Alibaba Cloud DashScope) API Key
BAILIAN_API_KEY=sk-your-api-key-here

# === OpenClaw Gateway ===
# Gateway authentication token (used by clients connecting to the gateway)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# === Fluss Connection ===
# External Fluss cluster address (deployed via the deploy/ directory)
FLUSS_BOOTSTRAP_SERVERS=192.168.1.100:9123

# === DingTalk Robot (Optional) ===
# DingTalk application credentials from the DingTalk Open Platform.
# Leave empty to disable DingTalk channel.
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
